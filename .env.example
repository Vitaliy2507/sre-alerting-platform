# Copy this file to app/.env and fill in real values.
# NEVER commit app/.env to version control.

# App
APP_VERSION=1.0.0

# Grafana
GF_SECURITY_ADMIN_PASSWORD=change_me_strong_password

# n8n
N8N_WEBHOOK_URL=https://your-domain/webhook/your-uuid-here

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Claude API
CLAUDE_API_KEY=your_api_key_here
CLAUDE_API_URL=https://api.proxyapi.ru/anthropic/v1/messages
